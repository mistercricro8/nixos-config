{
  "mcp": {
    "allowed": ["kindly-web-search", "searxng", "paper-search-mcp"]
  },
  "mcpServers": {
    "kindly-web-search": {
      "url": "http://localhost:8000/sse"
    },
    "searxng": {
      "url": "http://localhost:8001/sse"
    },
    "paper-search-mcp": {
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "research-paper-search-mcp-1",
        "python",
        "-m",
        "paper_search_mcp.server"
      ]
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "footer": {
      "items": ["workspace", "git-branch", "sandbox", "model-name", "quota"]
    }
  }
}
